#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Main deploy entry point. Prepares and deploys manifests to a
# Kubernetes namespace via the namespace-locked k wrapper.
set -euo pipefail

# Phase tracking and signal handling
UNINTERRUPTIBLE=false
SHUTDOWN_REQUESTED=false
ERROR_EXIT_CODE=0
PHASE="Pre Validation"
CHILD_PID=""
RUN_COMMAND=""

# Job mode sleep durations (seconds) - configurable via environment
POST_DEPLOY_SLEEP_SUCCESS="${POST_DEPLOY_SLEEP_SUCCESS:-600}"    # 10 minutes
POST_DEPLOY_SLEEP_FAILURE="${POST_DEPLOY_SLEEP_FAILURE:-86400}"  # 24 hours

# Interruptible sleep using read builtin - signals interrupt immediately
# unlike external sleep which blocks trap handlers until it completes.
# Defined conditionally so tests can override via export -f.
if ! declare -f interruptible_sleep > /dev/null 2>&1; then
  interruptible_sleep() {
    read -t "$1" -r || true
  }
fi

# Run a command in the background and wait, allowing trap handlers to
# fire immediately. The trap handler can then kill the child process.
run() {
  RUN_COMMAND="$*"
  "$@" &
  CHILD_PID=$!
  local rc=0
  while true; do
    wait "${CHILD_PID}" && rc=0 || rc=$?
    # kill -0 sends no signal - it just checks if the process is alive.
    # If a trap handler returned without exiting, wait exits early but
    # the child is still running, so we loop back and wait again.
    kill -0 "${CHILD_PID}" 2>/dev/null || break
  done
  CHILD_PID=""
  RUN_COMMAND=""
  return ${rc}
}

change_phase() {
  if [[ "${SHUTDOWN_REQUESTED}" == "true" ]]; then
    notify-info "Shutdown requested during ${PHASE} - respecting SIGTERM"
    notify-info "Expect a new environment version to complete deployment"
    exit 0
  fi
  UNINTERRUPTIBLE="$1"
  PHASE="$2"
}

handle_term() {
  if [[ "${UNINTERRUPTIBLE}" == "true" ]]; then
    notify-info "SIGTERM received during ${PHASE} - deferring until complete"
    SHUTDOWN_REQUESTED=true
  else
    notify-info "SIGTERM received during ${PHASE} - shutting down"
    if [[ -n "${CHILD_PID}" ]]; then
      kill -9 "${CHILD_PID}" 2>/dev/null || true
    fi
    exit "${ERROR_EXIT_CODE}"
  fi
}
trap 'handle_term' TERM

# SIGINT for manual exec-in reruns, not needed for Kube, but should respect Ctrl+C, too
handle_int() {
  notify-warning "SIGINT received - operator interference during ${PHASE}"
  if [[ -n "${CHILD_PID}" ]]; then
    kill -9 "${CHILD_PID}" 2>/dev/null || true
  fi
  exit 130
}
trap 'handle_int' INT

handle_err() {
  ERROR_EXIT_CODE=$?
  UNINTERRUPTIBLE=false
  local line_no="${BASH_LINENO[0]}"
  local command="${RUN_COMMAND:-${BASH_COMMAND}}"

  local error_type
  if [[ ${ERROR_EXIT_CODE} -ge 3 && ${ERROR_EXIT_CODE} -le 125 ]]; then
    error_type="Deployment"
  else
    error_type="Unexpected"
  fi

  local message="${error_type} error during ${PHASE}
  Exit code: ${ERROR_EXIT_CODE}
  Line: ${line_no}
  Command: ${command}
  Call stack:"
  for i in "${!FUNCNAME[@]}"; do
    message+="
    ${i}: ${FUNCNAME[${i}]}() at ${BASH_SOURCE[${i}]}:${BASH_LINENO[${i}]}"
  done
  message+="
Check pod logs for more detail or exec in and inspect the audit directory."

  notify-error "${message}"

  if [[ "${SHUTDOWN_REQUESTED}" == "true" ]]; then
    notify-info "Shutdown already requested - exiting"
    exit ${ERROR_EXIT_CODE}
  fi

  # Sleep behavior depends on DEPLOY_MODE
  # shellcheck disable=SC2154 # DEPLOY_MODE set by environment, validated by validate-environment
  if [[ "${DEPLOY_MODE}" == "deployment" ]]; then
    notify-info "Sleeping forever for inspection..."
    while true; do interruptible_sleep 3600; done
  else
    notify-info "Sleeping ${POST_DEPLOY_SLEEP_FAILURE}s before exit, to allow for inspection..."
    interruptible_sleep "${POST_DEPLOY_SLEEP_FAILURE}"
    exit ${ERROR_EXIT_CODE}
  fi
}
trap 'handle_err' ERR

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

# shellcheck source=src/scripts/lib/timestamp.bash
source "${LIB_DIR}/timestamp.bash"
# shellcheck source=src/scripts/lib/token-format.bash
source "${LIB_DIR}/token-format.bash"

# Defaults for thread-opening message - validation will catch if actually missing
ENVIRONMENT="${ENVIRONMENT:-UNKNOWN_ENVIRONMENT}"
VERSION="${VERSION:-UNKNOWN_VERSION}"
start_timestamp=$(human_timestamp)
start_seconds=$(date -u '+%s')

notify-info "*Starting ${ENVIRONMENT} version ${VERSION} deployment process* at ${start_timestamp}"

if ! validate-tooling; then
  notify-error "Tooling validation failed, this message may not send.

Use an appropriate base image and build process!"
  exit 43
fi
validate-environment
validate-container

# Token name and delimiter styles must be set in the image by the build
if ! validate_token_styles; then
  notify-error "Token style validation failed - check TOKEN_NAME_STYLE and TOKEN_DELIMITER_STYLE"
  exit 45
fi

# Path setup - RUN_BASE_PATH allows tests to override
base="${RUN_BASE_PATH:-/kd}"
work="${base}/work"
decrypted="${work}/decrypted"
audit="${work}/audit"

log "Initialising structure..."
mkdir -p "${work}/manifests"
mkdir -p "${decrypted}"
mkdir -p "${audit}"
mkdir -p "${audit}/kubectl"  # Optimise 'k' process
find "${work}"

change_phase false "Preparing manifests"
run prepare-manifests

change_phase false "Processing secrets"
run decrypt-secrets
# shellcheck disable=SC2154 # TOKEN_NAME_STYLE set by environment build process
run "${SCRIPT_DIR}/plugins/token-name-validators/${TOKEN_NAME_STYLE}" "${decrypted}"
run assemble-secrets

# TODO also record resource types so we can show what changes somehowe
run scan-images "before"

# TODO verify that the env is in a decent shape and note down details of bad stuff so we can ensre it hasn't gotten worse

change_phase false "Validating manifests"
run validate-manifests

change_phase true "Applying manifests"
run apply-manifests
# TODO apply in a more sophisticated way
# TODO verify things are happy after this action - await happiness - but don't accept increasing restarts on anything declared
# TODO clean up stuff we don't have declared - leave the environment exactly as declared

run scan-images "after"

run notify-images-changed

elapsed=$(( $(date -u '+%s') - start_seconds ))
notify-info "Deployment complete for ${ENVIRONMENT} version ${VERSION} in ${elapsed} seconds"

change_phase false "Complete"

# Sleep behavior depends on DEPLOY_MODE
# shellcheck disable=SC2154 # DEPLOY_MODE set by environment, validated by validate-environment
if [[ "${DEPLOY_MODE}" == "deployment" ]]; then
  notify-info "Deployment complete - sleeping forever..."
  while true; do interruptible_sleep 3600; done
else
  notify-info "Deployment complete - sleeping ${POST_DEPLOY_SLEEP_SUCCESS}s before exit..."
  interruptible_sleep "${POST_DEPLOY_SLEEP_SUCCESS}"
fi
