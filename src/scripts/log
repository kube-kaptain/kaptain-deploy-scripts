# Local logging only. Outputs to container stdout without fanning out
# to external notification providers. Use notify-info for external fanout.
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: log <message>" >&2
  echo "Error: message argument required" >&2
  exit 42
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Identify calling script name for echo provider
# Duplicated in src/scripts/lib/log.bash - keep in sync
# Get parent's full command line, skip interpreter if present, basename it
NOTIFY_CALLER=$(ps -o args= -p ${PPID} 2>/dev/null | # Full command line of the caller passed into awk:
  awk '{
         # Skip any interpreter, get the script path
         cmd = ($1 ~ /(bash|sh)$/) ? $2 : $1

         # Split the path on /
         n = split(cmd, parts, "/")

         # Print the last segment (the basename)
         print parts[n]
       }') || true
export NOTIFY_CALLER="${NOTIFY_CALLER:-UNKNOWN_CALLER}"

exec "${script_dir}/notify-info-echo" "$@"
