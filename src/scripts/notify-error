# Notify error dispatcher. Fans out to all notify-error-* provider scripts.
# Built-in: notify-error-echo. Optional: notify-error-slack, etc.
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: notify-error <message>" >&2
  echo "Error: message argument required" >&2
  exit 42
fi

message="$*"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Identify calling script name for echo providers
# Get parent's full command line, skip interpreter if present, basename it
NOTIFY_CALLER=$(ps -o args= -p ${PPID} 2>/dev/null | # Full command line of the caller passed into awk:
  awk '{
         # Skip any interpreter, get the script path
         cmd = ($1 ~ /(bash|sh)$/) ? $2 : $1

         # Split the path on /
         n = split(cmd, parts, "/")

         # Print the last segment (the basename)
         print parts[n]
       }') || true
export NOTIFY_CALLER="${NOTIFY_CALLER:-UNKNOWN_CALLER}"
start_time=$(date +%s)
threshold="${NOTIFY_TOO_SLOW_THRESHOLD:-10}"

# Find and execute all notify-error-* provider scripts
for provider in "${script_dir}"/notify-error-*; do
  [[ -x "${provider}" ]] || continue
  "${provider}" "${message}" || true
done

# Check if notifications took too long
elapsed=$(( $(date +%s) - start_time ))
if [[ "${elapsed}" -ge "${threshold}" ]]; then
  # Fan out directly to notify-warning-* to avoid recursion through dispatcher
  for provider in "${script_dir}"/notify-warning-*; do
    [[ -x "${provider}" ]] || continue
    "${provider}" "notify-error took ${elapsed}s (threshold: ${threshold}s)" || true
  done
fi
