# Built-in echo provider for notify-warning. Outputs to stderr with
# timestamp and caller script name.
# Format: 2026-01-25T14:32:15Z deploy: WARNING: message
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: notify-warning-echo <message>" >&2
  echo "Error: message argument required" >&2
  exit 42
fi

message="$*"
timestamp=$(date -u '+%Y-%m-%dT%H:%M:%SZ')

echo "${timestamp} ${NOTIFY_CALLER:-UNKNOWN_CALLER}: WARNING: ${message}" >&2
